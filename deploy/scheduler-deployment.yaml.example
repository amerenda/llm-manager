---
# Merge into GitOps alongside the backend API Deployment (see README in this folder).
# Image: same as llm-manager-backend (`python -m scheduler_worker`).
apiVersion: apps/v1
kind: Deployment
metadata:
  name: llm-manager-scheduler
spec:
  replicas: 2
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0
  template:
    spec:
      terminationGracePeriodSeconds: 120
      serviceAccountName: llm-manager-scheduler
      containers:
        - name: scheduler
          image: ghcr.io/example/llm-manager-backend:latest
          command: ["python", "-m", "scheduler_worker"]
          envFrom:
            - secretRef:
                name: llm-manager-backend-database
          env:
            - name: DISABLE_SCHEDULER
              value: "false"
            - name: LLM_MANAGER_AGENT_PSK
              valueFrom:
                secretKeyRef:
                  name: llm-manager-backend-apps
                  key: agent_psk
            - name: SCHEDULER_LEADER_BACKEND
              value: k8s
            - name: SCHEDULER_K8S_LEASE_NAME
              value: llm-manager-scheduler
          resources:
            requests:
              cpu: 50m
              memory: 256Mi
            limits:
              cpu: "1"
              memory: 1536Mi
