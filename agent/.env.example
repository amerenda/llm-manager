# LLM Agent environment — copy to .env and fill in values
# PSK must match the value in Bitwarden (llm-manager-agent-psk) and the k8s ExternalSecret
LLM_MANAGER_AGENT_PSK=your-psk-here

# Backend URL reachable from the GPU host.
#
# Preferred (agent running on a k3s node): NodePort via any node IP
#   BACKEND_URL=http://<any-node-ip>:30081
#   e.g. BACKEND_URL=http://10.100.20.19:30081
#
# Fallback (agent NOT on a k3s node): external hostname on amer.dev
#   BACKEND_URL=https://llm-manager-backend.amer.dev
#
BACKEND_URL=http://<node-ip>:30081

# Externally-reachable address of this agent (how the backend pod reaches it back)
AGENT_ADDRESS=http://murderbot.amer.home:8090
