# LLM Agent — copy to .env and fill in values (or run install.sh to generate)
#
# PSK must match the value in Bitwarden (llm-manager-agent-psk) and the k8s ExternalSecret
LLM_MANAGER_AGENT_PSK=your-psk-here

# Backend URL — always use HTTPS (PSK would be in cleartext over HTTP)
BACKEND_URL=https://llm-manager-backend.amer.dev

# AMD only — ROCm GFX version override for GPU compatibility
# Common values: 11.0.0 (RDNA 4 / RX 9070), 10.3.0 (RDNA 2)
# Leave unset for NVIDIA or if your AMD GPU works without it.
# HSA_OVERRIDE_GFX_VERSION=11.0.0

# Model storage path — overrides auto-detected Ollama models location.
# Use this if models are stored in a non-standard location.
# MODEL_STORAGE_PATH=/mnt/data/ollama/models

# Agent address is auto-detected at startup (host outbound IP).
# Override only if auto-detection picks the wrong interface:
# AGENT_ADDRESS=https://10.x.x.x:8090
