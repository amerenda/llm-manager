# LLM Agent environment — copy to .env and fill in values
# PSK must match the value in Bitwarden (llm-manager-agent-psk) and the k8s ExternalSecret
LLM_MANAGER_AGENT_PSK=your-psk-here

# Backend URL reachable from the GPU host
# If murderbot is a k8s node, use the ClusterIP: kubectl get svc llm-manager-backend -n llm-manager
# Example: http://10.43.4.139:8081
BACKEND_URL=http://<cluster-ip>:8081

# Externally-reachable address of this agent (how the backend pod reaches it)
AGENT_ADDRESS=http://murderbot.amer.home:8090
