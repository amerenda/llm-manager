# LLM Agent environment — copy to .env and fill in values
# PSK must match the value in Bitwarden (llm-manager-agent-psk) and the k8s ExternalSecret
LLM_MANAGER_AGENT_PSK=your-psk-here

# Backend URL — always use HTTPS (PSK would be in cleartext over HTTP)
BACKEND_URL=https://llm-manager-backend.amer.dev

# AGENT_ADDRESS is auto-detected at startup using the host's outbound IP.
# This requires network_mode: host in docker-compose (default).
# Override only if auto-detection picks the wrong interface:
# AGENT_ADDRESS=http://10.x.x.x:8090
