# Ollama server-level runtime tunables.
#
# This file is loaded into the Ollama Docker container (see compose.yaml's
# `ollama` / `ollama-amd` services). Changing values and running
#   docker compose --profile <nvidia-full|amd-full> up -d --force-recreate ollama
# restarts Ollama with the new settings.
#
# The llm-manager UI will eventually edit this file directly via the agent.
# All keys are optional — unset keys use Ollama's built-in defaults.
#
# Reference: https://github.com/ollama/ollama/blob/main/docs/faq.md

# Context window size. Default: 2048. Larger = more memory + more VRAM.
# Common values: 4096, 8192, 16384, 32768. Must be ≤ the model's trained max.
# OLLAMA_NUM_CTX=2048

# Enable Flash Attention. Default: off. Requires compatible GPU (RDNA 3+, Ampere+).
# Usually a large speedup and VRAM reduction if supported.
# OLLAMA_FLASH_ATTENTION=1

# KV cache quantization. Default: f16. Accepts: f16, q8_0, q4_0.
# q8_0 roughly halves KV-cache VRAM at small quality cost;
# q4_0 cuts further but can hurt long-context quality.
# Requires OLLAMA_FLASH_ATTENTION=1.
# OLLAMA_KV_CACHE_TYPE=q8_0

# Number of layers to offload to GPU. Default: all that fit.
# Set to a number to force partial offload. 0 = CPU-only.
# OLLAMA_NUM_GPU=

# Number of concurrent request slots per loaded model. Default: 1.
# Higher = more parallel throughput at the cost of VRAM and per-request latency.
# OLLAMA_NUM_PARALLEL=1

# Models loaded simultaneously. Default: 1. Under llm-manager's
# one-model-per-GPU scheduler this should stay 1 — multi-model loading
# would fight the scheduler's swap logic.
# OLLAMA_MAX_LOADED_MODELS=1

# How long to keep a model loaded after the last request. Default: 5m.
# Accepts durations like 30s, 5m, 2h, or "-1" for "keep forever".
# The llm-manager scheduler sets keep_alive=-1 per-request when it loads,
# so this is mostly a safety net for requests it doesn't route.
# OLLAMA_KEEP_ALIVE=5m

# Max queued requests. Default: 512. Past this, Ollama rejects with 503.
# OLLAMA_MAX_QUEUE=512

# Listen address. Default: 127.0.0.1:11434. Set to 0.0.0.0:11434 to expose
# Ollama on the network (NOT recommended — use llm-manager's proxy instead).
# OLLAMA_HOST=127.0.0.1:11434
